rules_version = '2';
service cloud2.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Blueprint for User Profiles
    function isValidUserProfile(data) {
      return data.userId is string 
        && data.userId.size() <= 128
        && data.email is string 
        && data.email.size() <= 200
        && data.isPremium is bool
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && data.keys().hasAll(['userId', 'email', 'isPremium', 'createdAt', 'updatedAt'])
        && data.keys().size() == 5;
    }

    // Validation Blueprint for Landing Page Entity
    function isValidLandingPage(data) {
      return data.id is string 
        && data.id.size() <= 128
        && data.ownerId is string 
        && data.ownerId.size() <= 128
        && data.businessName is string 
        && data.businessName.size() <= 100
        && data.tagline is string 
        && data.tagline.size() <= 200
        && data.theme is string 
        && data.theme.size() <= 50
        && data.colors is map
        && data.hero is map
        && data.features is list
        && data.features.size() <= 10
        && data.stats is list
        && data.stats.size() <= 10
        && data.testimonials is list
        && data.testimonials.size() <= 10
        && data.pricing is map
        && data.faqs is list
        && data.faqs.size() <= 15
        && data.footer is map
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && data.keys().hasAll([
          'id', 'ownerId', 'businessName', 'tagline', 'theme', 'colors', 
          'hero', 'features', 'stats', 'testimonials', 'pricing', 'faqs', 
          'footer', 'createdAt', 'updatedAt'
        ])
        && data.keys().size() == 15;
    }

    // Rules for Users
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidId(userId)
        && isValidUserProfile(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidId(userId)
        && isValidUserProfile(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
        
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Rules for Landing Pages
    match /landingPages/{pageId} {
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && incoming().ownerId == request.auth.uid
        && isValidId(pageId)
        && isValidLandingPage(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn() 
        && resource.data.ownerId == request.auth.uid
        && incoming().ownerId == request.auth.uid
        && isValidId(pageId)
        && isValidLandingPage(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
        
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
  }
}
